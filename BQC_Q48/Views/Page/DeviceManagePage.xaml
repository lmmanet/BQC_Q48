<Page x:Class="BQC_Q48.Views.DeviceManagePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:BQC_Q48.Views"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      Title="DeviceManagementPage"
      d:DesignHeight="450"
      d:DesignWidth="800"
      DataContext="{Binding Source={StaticResource Locator}, Path=DeviceManagePageViewModel}"
      Unloaded="DeviceManagePage_Unloaded"
      mc:Ignorable="d">


    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid>
            <StackPanel Orientation="Vertical">
                <Button Command="{Binding SwichCommand}" CommandParameter="AxisTestUC1" Content="伺服轴测试" />
                <Button Command="{Binding SwichCommand}" CommandParameter="StepAxisTestUC" Content="步进轴测试" />
                <Button Command="{Binding SwichCommand}" CommandParameter="ClawTestUC" Content="电爪测试" />
                <Button Command="{Binding SwichCommand}" CommandParameter="BalanceTestUC" Content="称台测试" />
                <Button Command="{Binding SwichCommand}" CommandParameter="ExtractIoTestUC" Content="提取IO测试" />
                <Button Command="{Binding SwichCommand}" CommandParameter="SampleStatusMonitor" Content="净化IO测试" />
                <Button Command="{Binding SwichCommand}" CommandParameter="IoTestUC" Content="离心中转IO测试" />
                <Button Command="{Binding SwichCommand}" CommandParameter="FieldBusTestUC" Content="总线测试" />
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1">
            <ContentControl Content="{Binding CurrentContent}" />

        </Grid>









    </Grid>




</Page>
